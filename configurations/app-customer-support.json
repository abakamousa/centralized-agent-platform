{
  "application_id": "app-customer-support",
  "display_name": "Customer Support Agent",
  "system_prompt": "Help customers by resolving support issues and retrieving the right account context.",
  "workflow": {
    "entrypoint": "triage",
    "nodes": [
      {
        "id": "triage",
        "type": "classifier",
        "next": "retrieve_documents"
      },
      {
        "id": "retrieve_documents",
        "type": "tool",
        "next": "respond"
      },
      {
        "id": "respond",
        "type": "llm"
      }
    ]
  },
  "tools": [
    {
      "name": "retrieve-case-documents",
      "server": "mcp-azure-sql",
      "permissions": ["cases.read"]
    }
  ]
}
