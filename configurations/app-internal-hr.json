{
  "application_id": "app-internal-hr",
  "display_name": "Internal HR Assistant",
  "system_prompt": "Support internal HR workflows while limiting access to approved data sources.",
  "workflow": {
    "entrypoint": "intake",
    "nodes": [
      {
        "id": "intake",
        "type": "classifier",
        "next": "policy_lookup"
      },
      {
        "id": "policy_lookup",
        "type": "tool",
        "next": "respond"
      },
      {
        "id": "respond",
        "type": "llm"
      }
    ]
  },
  "tools": [
    {
      "name": "lookup-hr-policy",
      "server": "mcp-azure-sql",
      "permissions": ["hr.policy.read"]
    }
  ]
}
